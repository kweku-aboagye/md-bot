# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USERNAME:PASSWORD@localhost:5432/mdbot

# ── Google Service Account ────────────────────────────────────────────────────
# Paste the entire service account JSON as a single-line JSON string.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"your-private-key-id","private_key":"-----BEGIN PRIVATE KEY-----\\nYOUR_KEY\\n-----END PRIVATE KEY-----\\n","client_email":"md-bot@your-project-id.iam.gserviceaccount.com","client_id":"your-client-id","token_uri":"https://oauth2.googleapis.com/token"}

# ── Google API access ─────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-api-key

# ── Email ─────────────────────────────────────────────────────────────────────
# Railway Hobby/Trial cannot use SMTP. Prefer Resend in production.
EMAIL_PROVIDER=

# Resend (recommended for Railway / production)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MD Bot <notifications@example.com>

# Gmail SMTP (works well for local development; requires Railway Pro+ in production)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# ── Routing ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
CELESTIAL_NOTIFICATION_EMAILS=leader1@example.com,leader2@example.com
ZAMAR_BAND_EMAILS=member1@example.com,member2@example.com

# ── Dashboard Pin ─────────────────────────────────────────────────────────────
# Leave blank for no PIN in local development.
DASHBOARD_PIN=
